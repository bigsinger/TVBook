<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#F6C343" />
            <stroke android:width="2dp" android:color="#FFFFFF" />
            <corners android:radius="8dp" />
            <padding android:left="10dp" android:top="8dp" android:right="10dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape>
            <solid android:color="#2A2A2A" />
            <stroke android:width="2dp" android:color="#F0C040" />
            <corners android:radius="8dp" />
            <padding android:left="10dp" android:top="8dp" android:right="10dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape>
            <solid android:color="#242424" />
            <stroke android:width="2dp" android:color="#F0C040" />
            <corners android:radius="8dp" />
            <padding android:left="10dp" android:top="8dp" android:right="10dp" android:bottom="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#00000000" />
            <stroke android:width="2dp" android:color="#00000000" />
            <corners android:radius="8dp" />
            <padding android:left="10dp" android:top="8dp" android:right="10dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>
