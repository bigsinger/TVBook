<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="48dp"
        android:paddingRight="48dp">

        <TextView
            android:id="@+id/txtAudioCover"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:background="@drawable/tv_audio_cover"
            android:gravity="center"
            android:text="♪"
            android:textColor="#F0C040"
            android:textSize="72sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/viewPlayerControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC0B0B0B"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProgressCurrent"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="left|center_vertical"
                android:textColor="#F0C040"
                android:textSize="10sp" />

            <SeekBar
                android:id="@+id/progressBar"
                style="@android:style/Widget.SeekBar"
                android:layout_width="0dp"
                android:layout_height="18dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:progressDrawable="@drawable/tv_progress" />

            <TextView
                android:id="@+id/txtProgressTotal"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="right|center_vertical"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="2dp">

            <Button
                android:id="@+id/btnPrePage"
                style="@style/TvOverlayButton"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="上一首" />

            <Button
                android:id="@+id/btnNextPage"
                style="@style/TvOverlayButton"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="下一首" />

            <Button
                android:id="@+id/btnPlayPause"
                style="@style/TvOverlayButton"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="暂停/继续" />

            <Button
                android:id="@+id/btnFavorite"
                style="@style/TvOverlayButton"
                android:layout_width="58dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="收藏" />

            <Button
                android:id="@+id/btnChangePlayMode"
                style="@style/TvOverlayButton"
                android:layout_width="54dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="自动" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="right|center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingTop="3dp"
            android:paddingRight="8dp">

            <TextView
                android:id="@+id/txtAudioName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:singleLine="true"
                android:textColor="#E6E6E6"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtAudioMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:singleLine="true"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
