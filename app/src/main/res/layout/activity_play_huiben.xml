<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:onClick="onClick"
        android:scaleType="fitCenter" />

    <TextView
        android:id="@+id/txtViewInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="left|top"
        android:layout_margin="12dp"
        android:background="@drawable/tv_status_pill"
        android:gravity="left"
        android:paddingLeft="8dp"
        android:paddingTop="4dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp"
        android:textColor="#EEEEEE"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/viewPlayerControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC0B0B0B"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtProgressCurrent"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="left|center_vertical"
                android:textColor="#F0C040"
                android:textSize="10sp" />

            <ProgressBar
                android:id="@+id/pageProgressBar"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:progressDrawable="@drawable/tv_progress" />

            <TextView
                android:id="@+id/txtProgressTotal"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="right|center_vertical"
                android:textColor="#888888"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingTop="2dp">

            <Button
                android:id="@+id/btnPrePage"
                style="@style/TvOverlayButton"
                android:layout_width="54dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="上页" />

            <Button
                android:id="@+id/btnNextPage"
                style="@style/TvOverlayButton"
                android:layout_width="54dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="下页" />

            <Button
                android:id="@+id/btnPrevBook"
                style="@style/TvOverlayButton"
                android:layout_width="54dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="上本" />

            <Button
                android:id="@+id/btnNextBook"
                style="@style/TvOverlayButton"
                android:layout_width="54dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="下本" />

            <Button
                android:id="@+id/btnPlayPause"
                style="@style/TvOverlayButton"
                android:layout_width="68dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="暂停/继续" />

            <Button
                android:id="@+id/btnFavorite"
                style="@style/TvOverlayButton"
                android:layout_width="58dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="收藏" />

            <Button
                android:id="@+id/btnChangePlayMode"
                style="@style/TvOverlayButton"
                android:layout_width="54dp"
                android:layout_height="wrap_content"
                android:onClick="onClick"
                android:text="自动" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
