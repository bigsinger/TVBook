<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0B"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#141414"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingTop="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.05"
            android:orientation="vertical"
            android:paddingRight="14dp">

            <TextView
                android:id="@+id/txtAppTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="18dp"
                android:text="TVBook   v1.4"
                android:textColor="#F0C040"
                android:textSize="24sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A2A2A" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="14dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/viewMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2A2A2A" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingRight="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/txtSectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:singleLine="true"
                    android:text="内容"
                    android:textColor="#888888"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/txtSectionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 项"
                    android:textColor="#555555"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="14dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:id="@+id/viewSubMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2A2A2A" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.05"
            android:orientation="vertical"
            android:paddingLeft="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="系统"
                android:textColor="#555555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtSystemVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Android"
                android:textColor="#CCCCCC"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="U盘"
                android:textColor="#555555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtUsbPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="/mnt/usb"
                android:textColor="#5CB85C"
                android:textSize="15sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="配置"
                android:textColor="#555555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtConfigPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="/tvbooks/config/"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="续播"
                android:textColor="#555555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtResumeInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="—"
                android:textColor="#CCCCCC"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#222222" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="收藏"
                android:textColor="#555555"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtFavCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="0"
                android:textColor="#F0C040"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:singleLine="true"
                    android:text="自动间隔(秒)"
                    android:textColor="#888888"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnDec"
                    style="@style/TvSmallButton"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:onClick="onDecDelaySeconds"
                    android:text="-" />

                <TextView
                    android:id="@+id/txtDelaySecondsPerAudio"
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/btnInc"
                    style="@style/TvSmallButton"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:onClick="onDecDelaySeconds"
                    android:text="+" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/viewQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPlayMode"
                    style="@style/TvSmallButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:onClick="onClick"
                    android:text="自动" />

                <Button
                    android:id="@+id/btnSyncCatalog"
                    style="@style/TvSmallButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:onClick="onSyncCatalog"
                    android:text="同步" />

                <Button
                    android:id="@+id/btn_open_document_tree"
                    style="@style/TvSmallButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:onClick="openDocumentTree"
                    android:text="授权" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_exit"
                style="@style/TvButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:onClick="exitApp"
                android:text="退出" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtKeyHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:paddingLeft="24dp"
        android:paddingTop="8dp"
        android:paddingRight="24dp"
        android:paddingBottom="8dp"
        android:text="↑↓←→ 选择    OK 确认/暂停    Menu 同步目录/控制栏    Bookmark 收藏    Back 返回"
        android:textColor="#888888"
        android:textSize="12sp" />
</LinearLayout>
